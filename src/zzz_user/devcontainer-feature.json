{
  "name": "User",
  "id": "user",
  "version": "0.0.1",
  "description": "Add a non-root user",
  "options": {
    "username": {
      "type": "string",
      "default": "contend",
      "description": "User name (string)"
    },
    "uid": {
      "type": "string",
      "default": "1001", //resolute has userid 1000 already, whereas jammy did not
      "description": "User ID (string)"
    },
    "docker_group": {
      "type": "boolean",
      "default": true,
      "description": "Add the user to the docker group (boolean)"
    }
  }
  // "installsAfter": [
  //   "../helm"
  // ]
}