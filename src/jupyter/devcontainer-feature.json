{
  "name": "Jupyter",
  "id": "jupyter",
  "version": "0.0.1",
  "description": "Install JupyterLab",
  "options": {
    "venvPath": {
      "type": "string",
      "default": "/opt/devcontainer-venv",
      "description": "Virtual environment install path"
    }
  },
  "containerEnv": {
    "VIRTUAL_ENV": "/opt/devcontainer-venv",
    "PATH": "/opt/devcontainer-venv/bin:${PATH}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/devcontainer-venv/bin/python",
        "jupyter.jupyterServerType": "remote",
        "jupyter.jupyterServerUri": "http://127.0.0.1:8888/",
        "jupyter.kernelspec": {
          "display_name": "Python 3 (ipykernel)",
          "language": "python",
          "name": "python3"
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "postStartCommand": "bash -lc 'set -e; LOG=/tmp/jupyter.log; if ! ss -ltn 2>/dev/null | awk \"$4 ~ /:8888/\"; then nohup /usr/local/bin/start-jupyter.sh > \"$LOG\" 2>&1 & fi; for i in {1..30}; do ss -ltn 2>/dev/null | awk \"$4 ~ /:8888/\" && echo \"Jupyter Lab is listening on 8888\" && exit 0; sleep 1; done'"
}